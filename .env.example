# Copy to .env — Vite only exposes variables prefixed with VITE_
# Get values from Supabase: Project Settings → API

# Canonical site URL (no trailing slash). Used at build time for og:image / og:url in index.html.
# VITE_SITE_ORIGIN=https://lustforge.app
# Google Analytics measurement id (accepts raw digits and auto-prefixes with G-).
# VITE_GA_MEASUREMENT_ID=531474793

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use either the anon "public" key (typical) or the newer "publishable" key name:
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Admin UI gate (Navbar /admin link, Admin shell). Defaults to lustforgeapp@gmail.com if unset.
# Comma-separated = multiple accounts get admin (each must match a real Auth email). Gmail/Googlemail: dots in the local part are ignored when matching.
# VITE_ADMIN_EMAIL=lustforgeapp@gmail.com

# Optional: your Supabase Auth user UUID(s). If set, admin UI matches this id even if you change email later.
# Dashboard → Authentication → Users → copy User UID.
# VITE_ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000

# Optional: reserved forge-operator display handles (comma-separated, case-insensitive). Default lustforge.
# Must match together with VITE_ADMIN_EMAIL or VITE_ADMIN_USER_IDS — not username alone.
# VITE_ADMIN_HANDLES=lustforge,LustForge

# Set to false (or 0 / off) to hide Sign up on /auth — invite-only / solo operator. Pair with Supabase → Authentication → disable new signups if you want server-side enforcement too.
# VITE_PUBLIC_SIGNUP=false

# --- Edge Functions (NOT in .env — set in Supabase Dashboard → Project Settings → Edge Functions → Secrets) ---
# Required for chat, image gen, admin companion tools, parse prompt:
#   XAI_API_KEY   OR   GROK_API_KEY   (same value from https://console.x.ai/)
# Optional: GROK_IMAGE_MODEL (default grok-imagine-image)
# Optional: ADMIN_USER_IDS — same comma-separated Auth user UUIDs as VITE_ADMIN_USER_IDS (Forge Assistant admin gate).
# Auto-provided by Supabase: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
