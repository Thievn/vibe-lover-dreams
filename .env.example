# Copy to .env — Vite only exposes variables prefixed with VITE_
# Get values from Supabase: Project Settings → API

# Canonical site URL (no trailing slash). Used at build time for og:image / og:url in index.html.
# VITE_SITE_ORIGIN=https://lustforge.app
# Google Analytics 4 measurement id (accepts raw digits and auto-prefixes with G-).
# Build injects gtag.js into index.html from this value (default G-JF1831WS0G if unset). Set to false / 0 / off to disable.
# VITE_GA_MEASUREMENT_ID=G-JF1831WS0G

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# Use either the anon "public" key (typical) or the newer "publishable" key name:
VITE_SUPABASE_ANON_KEY=your-anon-key
# VITE_SUPABASE_PUBLISHABLE_KEY=

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
# Paste public key here (browser). Paste both keys + contact into Supabase Edge secrets (see below).
# VITE_VAPID_PUBLIC_KEY=BGx...

# Admin UI gate (Navbar /admin link, Admin shell). Comma-separated = extra operator emails.
# lustforgeapp@gmail.com is always allowed (merged in) so setting only a custom address here cannot lock out the founder mailbox.
# Gmail/Googlemail: dots and +tags in the local part are ignored when matching.
# VITE_ADMIN_EMAIL=admin@lustforge.app

# Optional: your Supabase Auth user UUID(s). If set, admin UI matches this id even if you change email later.
# Dashboard → Authentication → Users → copy User UID.
# VITE_ADMIN_USER_IDS=00000000-0000-0000-0000-000000000000

# Optional: reserved forge-operator display handles (comma-separated, case-insensitive). Default lustforge.
# Must match together with VITE_ADMIN_EMAIL or VITE_ADMIN_USER_IDS — not username alone.
# VITE_ADMIN_HANDLES=lustforge,LustForge

# Open registration: set to true / 1 / on so any email can use Sign up. When unset or false, only these three inboxes may sign up:
# lustforgeapp@gmail.com, thievnsden@gmail.com, deanoneill69@gmail.com (see src/config/auth.ts + Auth hook migration).
# VITE_PUBLIC_SIGNUP=true

# --- Supabase Auth email (confirm sign-up, password reset) — NOT configured in this file ---
# Supabase sends these from your hosted project. Waitlist / marketing mail uses Edge + Resend (RESEND_API_KEY); that is separate.
# If the app says a confirmation was sent but nothing arrives: use Dashboard → Authentication → SMTP Settings → enable Custom SMTP
# (Resend, SendGrid, Postmark, etc.). Built-in mail is rate-limited and often lands in spam or is delayed.
# Also verify Authentication → URL Configuration (Site URL + Redirect URLs include your live origin, e.g. https://lustforge.app/auth).
# Logs → Auth (or Edge) may show send errors. Guide: https://supabase.com/docs/guides/auth/auth-smtp
#
# Branded Auth email HTML lives in `supabase/templates/` and is wired in `supabase/config.toml` under `[auth.email.template.*]`.
# Push to your hosted Supabase project: `supabase config push` (from repo root; must match the same project as VITE_SUPABASE_URL).
# Or paste HTML into Dashboard → Authentication → Email Templates if the CLI is linked to a different ref than production.
# If you see "Error sending confirmation email" after enabling Custom SMTP, the handoff to your provider failed — deleting
# Auth users does not cause that. Typical fixes (Resend example — see Resend → Settings → SMTP):
#   Host smtp.resend.com · Port 465 (SSL) · Username resend · Password = your Resend API key (not the Edge secret name).
#   Sender email must use a domain you verified in Resend (not an arbitrary @gmail.com as the SMTP from-address).
#   Re-save SMTP in Supabase after rotating the API key; wait a minute if you hit rate limits from many test signups.

# --- Edge Functions (NOT in .env — set in Supabase Dashboard → Project Settings → Edge Functions → Secrets) ---
# Optional: `create-user` invite endpoint — comma-separated emails allowed to POST { email, password } (default: founder + QA inboxes).
# CREATE_USER_ALLOWED_EMAILS=lustforgeapp@gmail.com,thievnsden@gmail.com,deanoneill69@gmail.com
# Lovense remote control (QR pairing + send-device-command). Use the exact secret names below (not "lovins_*").
# In Lovense Developer Dashboard → Callback URL, set:
#   https://<your-project-ref>.supabase.co/functions/v1/lovense-callback
# Required:
#   LOVENSE_DEVELOPER_TOKEN
# Optional — only if your Lovense integration docs require them (Standard LAN API in this repo uses the token only):
#   LOVENSE_DEVELOPER_KEY
#   LOVENSE_DEVELOPER_IV
# Hybrid AI (Edge Function secrets) — **product chat and assistants use xAI Grok only** (`grok-chat`, `admin-companion-chat`, etc.).
#   TOGETHER_API_KEY — optional legacy Together / FLUX if you still use it in a fork.
#   TOGETHER_IMAGE_MODEL — optional global override for image slug (default in code: black-forest-labs/FLUX.2-dev).
#   TOGETHER_IMAGE_MODEL_FALLBACK — optional second slug if the primary errors (default: black-forest-labs/FLUX.2-flex).
#   TOGETHER_IMAGE_STEPS — optional 1–50 (default 28).
#   TOGETHER_VIDEO_MODEL — reserved for future Together video; optional (per-user override: profiles.together_video_model in Settings).
# Optional: TOGETHER_API_BASE_URL — default https://api.together.xyz/v1
# Optional: TOGETHER_CHAT_MODEL — Together chat completions (see togetherClient.ts)
# Optional: TOGETHER_FORGE_PARSE_MODEL — unused when Forge parse runs on Grok (`GROK_FORGE_PARSE_MODEL`).
#   XAI_API_KEY   OR   GROK_API_KEY — Grok stills, rewriter, parse-companion-prompt, grok-chat (Live Voice + teaser), TTS/STT, Grok video (I2V). https://console.x.ai/
# Optional: GROK_IMAGE_MODEL — still slug (default grok-imagine-image)
# Optional: GROK_REWRITE_MODEL — rewrite before stills (defaults to GROK_CHAT_MODEL)
# Optional: GROK_FORGE_PARSE_MODEL — parse-companion-prompt (defaults to GROK_CHAT_MODEL)
# Optional: GROK_CHAT_MODEL — classic chat, smart replies, Live Voice + defaults above (default grok-4.3; grok-chat sends x-grok-conv-id per user+companion for prompt cache affinity)
# Optional: GROK_VISION_MODEL / GROK_APPEARANCE_VISION_MODEL / GROK_VISION_CLASSIFY_MODEL — image understanding (defaults: grok-4.3 → grok-2-vision-latest → grok-2-vision; see grokVisionModels.ts)
# Optional: GROK_VIDEO_MODEL — profile + chat I2V clips (default grok-imagine-video)
# Optional: GROK_VIDEO_DURATION_SECONDS — profile loop length 5–15s (default 10)
# Optional: GROK_CHAT_VIDEO_DURATION_SECONDS — in-chat clip length 5–15s (default 10)
# Tensor.art TAMS (Edge: `generate-image-tensor`, nude stills + nude chat I2V) — set TENSOR_API_KEY from https://tams.tensor.art/app
# Optional: TENSOR_API_BASE_URL — copy from your TAMS app if not default
# Nude dual-model (numeric model ids from https://tensor.art/models/<id>):
#   TENSOR_NUDE_REALISTIC_IMAGE_MODEL, TENSOR_NUDE_STYLIZED_IMAGE_MODEL
#   TENSOR_NUDE_REALISTIC_VIDEO_MODEL, TENSOR_NUDE_STYLIZED_VIDEO_MODEL
# Optional fallbacks: TENSOR_REALISTIC_IMAGE_MODEL, TENSOR_STYLIZED_IMAGE_MODEL, TENSOR_STYLIZED_VIDEO_MODEL, TENSOR_VIDEO_MODEL
# Optional per-user profiles.together_image_model — legacy; production stills use Grok Imagine (generate-image) unless you fork.
# Optional: ADMIN_USER_IDS — same comma-separated Auth user UUIDs as VITE_ADMIN_USER_IDS (Forge Assistant admin gate).
# Pre-launch API lock (Edge secrets): `PUBLIC_API_TEASER_MODE` alone mirrors profile-teaser ops / docs and does **not**
# block signed-in chat or generation. To restore the old “preview — unlock at launch” 403 for all non-admins, also set:
#   PUBLIC_API_TEASER_BLOCK_LOGGED_IN=true
# Auto-provided by Supabase: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
#
# Web Push — Edge Function secrets (Dashboard → Edge Functions → Secrets), deploy `web-push-subscribe` + `web-push-send`:
#   VAPID_PUBLIC_KEY     (same string as VITE_VAPID_PUBLIC_KEY)
#   VAPID_PRIVATE_KEY    (private key from web-push generate-vapid-keys)
#   VAPID_CONTACT        optional, default mailto:support@lustforge.app — must be a mailto: or https: URL
